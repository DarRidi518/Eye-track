# Функция для проверки пользователя
def verify_user():
    root = tk.Tk()
    root.withdraw()

    user_login = simpledialog.askstring("Вход/Регистрация",
                                        "Введите ваш логин:",
                                        parent=root)

    if not user_login:
        messagebox.showwarning("Предупреждение", "Логин не может быть пустым!")
        root.destroy()
        return False

    cursor.execute("SELECT password_hash, code_hash FROM users WHERE login = ?", (user_login,))
    result = cursor.fetchone()

    if result:
        stored_password_hash, stored_code_hash = result

        user_password = simpledialog.askstring("Вход",
                                               "Введите ваш пароль:",
                                               parent=root,
                                               show='*')

        if not user_password:
            messagebox.showwarning("Предупреждение", "Пароль не может быть пустым!")
            root.destroy()
            return False

        user_password_hash = hashlib.sha256(user_password.encode()).hexdigest()

        if user_password_hash == stored_password_hash:
            messagebox.showinfo("Успех!", f"Добро пожаловать, {user_login}!\nДоступ разрешен.")
            root.destroy()
            return True
        else:
            messagebox.showerror("Ошибка", "Неверный пароль!\nДоступ запрещен.")
            root.destroy()
            return False

    else:
        messagebox.showinfo("Регистрация", f"Логин '{user_login}' свободен!\nДавайте создадим аккаунт.")

        while True:
            user_password = simpledialog.askstring("Регистрация - Пароль",
                                                   "Придумайте пароль:\n(мин. 6 символов, заглавные, строчные, цифры)",
                                                   parent=root,
                                                   show='*')

            if not user_password:
                messagebox.showwarning("Предупреждение", "Пароль не может быть пустым!")
                root.destroy()
                return False

            is_valid, message = is_password_valid(user_password)
            if is_valid:
                confirm_password = simpledialog.askstring("Регистрация - Подтверждение",
                                                          "Повторите пароль:",
                                                          parent=root,
                                                          show='*')
                if user_password == confirm_password:
                    messagebox.showinfo("Успех", message)
                    break
                else:
                    messagebox.showerror("Ошибка", "Пароли не совпадают!\nПопробуйте снова.")
            else:
                messagebox.showerror("Ошибка", message)

        generated_code = generate_code()
        generated_code_hash = hashlib.sha256(generated_code.encode()).hexdigest()
        print("Ваш код:", generated_code)

        while True:
            user_code = simpledialog.askstring("Регистрация - Код",
                                               "Введите 16-значный код\n(формат XXXX-XXXX-XXXX-XXXX):",
                                               parent=root)

            if not user_code:
                messagebox.showwarning("Предупреждение", "Код не может быть пустым!")
                continue

            user_code_normalized = user_code.strip().upper()
            user_code_hash = hashlib.sha256(user_code_normalized.encode()).hexdigest()

            if user_code_hash == generated_code_hash:
                messagebox.showinfo("Успех!", "Код верный!")
                break
            else:
                messagebox.showerror("Ошибка",
                                     f"Код не совпадает!\n\n"
                                     f"Ваш код: {generated_code}\n"
                                     f"Вы ввели: {user_code_normalized}")

        try:
            user_password_hash = hashlib.sha256(user_password.encode()).hexdigest()
            cursor.execute("INSERT INTO users (login, password_hash, code_hash) VALUES (?, ?, ?)",
                           (user_login, user_password_hash, generated_code_hash))
            connection.commit()
            messagebox.showinfo("Регистрация завершена!",
                                f"Поздравляем, {user_login}!\n\n"
                                f"Аккаунт успешно создан.\n\n"
                                f"Сохраните код в надежном месте!")
            root.destroy()
            return True
        except sqlite3.IntegrityError:
            messagebox.showerror("Ошибка", "Произошла ошибка при создании аккаунта!")
            root.destroy()
            return False


# Вызываем функцию проверки пользователя
verify_user()


def ensure_qt_app():
    app = QtWidgets.QApplication.instance()
    if app is None:
        app = QtWidgets.QApplication(sys.argv)
    return app


# Глобальные параметры и состояния
cap = cv2.VideoCapture(0)
left_counter = 0
right_counter = 0

th_value = 5
NO_EYES_MAX_FRAMES = 60  # сколько кадров без обнаружения глаз допустимо
NO_BLINK_MAX_FRAMES = 60  # сколько кадров без обнаружения моргания
warning_shown = False  # не показываем повторно одно и то же окно
no_eyes_frames = 0  # счетчик кадров без обнаружения глаз
no_blink_frames = 0  # счетчик кадров без моргания

# Флаг уведомления, что пользователь закрыл окно
warning_closed_by_user = False

GIVEUP_AFTER_FRAMES = 100  # кадров после предупреждения до выхода
giveup_frames = 0  # счетчик кадров после предупреждения


# Функция для thresholding (вынесена из цикла)
def thresholding(value):
    global left_counter, right_counter, no_eyes_frames
    if (value <= 54):
        left_counter += 1
        if (left_counter > th_value):
            print('RIGHT')
            left_counter = 0
            no_eyes_frames = 0
    elif (value >= 54):
        right_counter += 1
        if (right_counter > th_value):
            print('LEFT')
            right_counter = 0
            no_eyes_frames = 0


# Иммутабельная функция показа окна предупреждения
def show_warning_window_pyqt(message):
    app = ensure_qt_app()

    w = QtWidgets.QWidget()
    w.setWindowTitle('Предупреждение')
    w.setFixedSize(400, 120)

    layout = QtWidgets.QVBoxLayout()
    label = QtWidgets.QLabel(message)
    label.setAlignment(QtCore.Qt.AlignCenter)
    layout.addWidget(label)

    btn = QtWidgets.QPushButton('Закрыть')
    layout.addWidget(btn, alignment=QtCore.Qt.AlignCenter)

    w.setLayout(layout)

    def on_close_clicked():
        global warning_closed_by_user
        warning_closed_by_user = True
        w.close()

    btn.clicked.connect(on_close_clicked)

    w.setWindowModality(QtCore.Qt.ApplicationModal)
    w.show()

    # Запуск обработчика событий до закрытия окна
    while w.isVisible():
        app.processEvents()
        time.sleep(0.01)


# Запуск предупреждения в отдельном потоке
def trigger_warning_async():
    threading.Thread(target=show_warning_window_pyqt, args=("У вас закрыты глаза!",), daemon=True).start()


# Визуальная подпись на кадре
def debug_show_warning_text(frame, text):
    cv2.putText(frame, text, (10, 30),
                cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2)


# Главный цикл
while True:
    ret, frame = cap.read()
    if not ret:
        break

    # Линии (визуал)
    cv2.line(frame, (320, 0), (320, 480), (0, 200, 0), 2)
    cv2.line(frame, (0, 200), (640, 200), (0, 200, 0), 2)

    # Обработка кадров
    if ret:
        col = frame.copy()

        # Приведение к градациям серого
        frame_gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        pupilFrame = frame_gray
        clahe_img = frame_gray
        blur_img = frame_gray
        edges = frame_gray

        # Загрузка каскада глаз
        eyes = cv2.CascadeClassifier('haarcascade_eye.xml')
        detected = eyes.detectMultiScale(frame_gray, 1.3, 5)

        eyes_found_in_this_frame = False
        for (x, y, w, h) in detected:
            eyes_found_in_this_frame = True
            cv2.rectangle(frame_gray, (x, y), (x + w, y + h), (0, 0, 255), 1)
            cv2.line(frame_gray, (x, y), (x + w, y + h), (0, 0, 255), 1)
            cv2.line(frame_gray, (x + w, y), (x, y + h), (0, 0, 255), 1)

            # Пример обработки: можно локально применять гистограмму и окружности
            pupilFrame = cv2.equalizeHist(frame_gray)
            cl1 = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
            blurred_for_circles = cv2.GaussianBlur(frame_gray, (5, 5), 0)

            # Поиск окружностей
            circles = cv2.HoughCircles(blurred_for_circles, cv2.HOUGH_GRADIENT, 1, 20,
                                       param1=50, param2=30, minRadius=7, maxRadius=21)
            if circles is not None:
                circles = np.round(circles[0, :]).astype("int")
                for (cx, cy, r) in circles:
                    cv2.circle(pupilFrame, (cx, cy), r, (0, 255, 255), 2)
                    cv2.rectangle(pupilFrame, (cx - 5, cy - 5), (cx + 5, cy + 5), (0, 128, 255), -1)
                    thresholding(cx)

        # Логика отсутствия глаз
        if detected is not None and len(detected) > 0:
            no_eyes_frames = 0
        else:
            no_eyes_frames += 1

        # Логика обнаружения моргания
        if detected is not None and len(detected) > 0:
            no_blink_frames = 0
        else:
            no_blink_frames += 1

        if no_eyes_frames > NO_EYES_MAX_FRAMES:
            if not warning_shown:
                trigger_warning_async()
                warning_shown = True
                giveup_frames = 0  # начать отсчет после показа предупреждения
            debug_show_warning_text(frame, "Вы не подаете признаков жизни!")

            # Если предупреждение было закрыто пользователем — можно сбросить флаги и продолжать
            if warning_closed_by_user:
                warning_closed_by_user = False
                warning_shown = False
                giveup_frames = 0

            # Логика "сдать" по времени игнорирования
            else:
                giveup_frames += 1
                if giveup_frames > GIVEUP_AFTER_FRAMES:
                    print("Водитель спит!")
                    break

        # Если водитель не моргает
        if no_blink_frames > NO_BLINK_MAX_FRAMES:
            if not warning_shown:
                trigger_warning_async()
                warning_shown = True
                giveup_frames = 0
            debug_show_warning_text(frame, "Вы не подаете признаков жизни!")

            if warning_closed_by_user:
                warning_closed_by_user = False
                warning_shown = False
                giveup_frames = 0

            else:
                giveup_frames += 1
                if giveup_frames > GIVEUP_AFTER_FRAMES:
                    print("Водитель не живой организм!!")
                    break

        # Рендер
        cv2.imshow('image', pupilFrame)

        # Выход по клавише
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

cap.release()
cv2.destroyAllWindows()
connection.close()
